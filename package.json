{
  "name": "musehub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://github.com/fmw666/musehub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fmw666/musehub.git"
  },
  "bugs": {
    "url": "https://github.com/fmw666/musehub/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "ci": "npm run validate:showcases && npm run lint && npm run guard:design && npm run guard:motion && npm run test && npm run build && npm run guard:perf -- --no-build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"vitest.config.ts\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"vite.config.ts\" \"vitest.config.ts\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "validate:showcases": "node scripts/validate-community-showcases.mjs",
    "build:showcase:evomap-themes": "node scripts/build-evomap-design-themes.mjs",
    "guard": "node scripts/structural-guard.mjs",
    "guard:design": "node scripts/design-guard.mjs",
    "guard:motion": "node scripts/motion-report.mjs",
    "guard:perf": "node scripts/perf-guard.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "three": "^0.169.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@heroui/react": "^3.0.3",
    "@heroui/styles": "^3.0.3",
    "@tailwindcss/vite": "^4.2.4",
    "lucide-react": "^1.14.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4"
  }
}
